# Ensure shell scripts and Dockerfile always use LF in the repo
entrypoint.sh   text eol=lf
*.sh            text eol=lf
Dockerfile      text eol=lf
inference.py    text eol=lf

# Standard Python/text files
*.py            text eol=lf
*.yaml          text eol=lf
*.toml          text eol=lf
*.txt           text eol=lf
*.md            text eol=lf

# Binaries — don't touch line endings
*.pt            binary
*.png           binary
*.jpg           binary
*.mp4           binary
