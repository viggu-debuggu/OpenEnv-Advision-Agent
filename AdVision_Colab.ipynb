   "source": [
    "# AdVision AI - Google Colab Workspace\n",
    "\n",
    "This notebook bridges your AdVision OpenEnv project to a **Google Colab Cloud GPU**.\n",
    "Upload the `AdVision` project folder to your Google Drive, then execute these cells sequentially to run the Gradio interface with GPU acceleration."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 1. Mount your Google Drive\n",
    "from google.colab import drive\n",
    "drive.mount('/content/drive')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 2. Navigate to your project folder\n",
    "# Ensure your folder is uploaded exactly as 'AdVision' in the root of your Google Drive.\n",
    "import os\n",
    "project_path = '/content/drive/MyDrive/AdVision'\n",
    "if os.path.exists(project_path):\n",
    "    os.chdir(project_path)\n",
    "    print(f\"✅ Switched working directory to: {project_path}\")\n",
    "else:\n",
    "    print(f\"❌ Could not find {project_path}.")\n",
    "    print(\"Please make sure the AdVision folder is uploaded to your Google Drive root.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 3. Install packages and project dependencies\n",
    "!pip install -e .\n",
    "!pip install gradio python-dotenv ultralytics openenv-core"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 4. Launch the AdVision UI Simulator\n",
    "# This will output a public Gradio URL (e.g., https://xxxx.gradio.live) \n",
    "# Click the link to open the UI in your browser and start processing videos!\n",
    "import nest_asyncio\n",
    "nest_asyncio.apply()\n",
    "\n",
    "from app_ui import create_ui\n",
    "from dotenv import load_dotenv\n",
    "\n",
    "load_dotenv() # Load your API Keys\n",
    "\n",
    "ui = create_ui()\n",
    "ui.launch(share=True, debug=True)"
   ]
  }
